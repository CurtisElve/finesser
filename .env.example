# Copy to `.env` on your machine or VPS (`cp .env.example .env` then edit).
# Bun loads `.env` automatically for `bun run` / `bun start`.

# --- HTTP ---
# Port for `Bun.serve` (nginx can proxy to this).
PORT=3000

# --- Solana RPC (used by server routes + `/api/timing-escrow-config` for the browser settle flow) ---
# Use a URL that matches the cluster users select in Phantom (mainnet vs devnet).
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# --- Timing escrow (on-chain program; default matches production deploy) ---
TIMING_ESCROW_PROGRAM_ID=3PEthrNepy4UErzXeSAxpwrhvDMHUfKzitFQxSNdCvyu

# --- Pump / launch (optional unless you use `/api/launch` or `/api/quote`) ---
PUMP_PORTAL_API_KEY=
PUMP_CREATION_FEE_SOL=0.021
PUMP_EXTRA_BUFFER_SOL=0.002

# --- Burner wallet (optional unless you use airdrop / launch token paths) ---
BURNER_PRIVATE_KEY_BASE58=

# --- Airdrop preview (optional) ---
AIRDROP_TOKEN_ADDRESS=
AIRDROP_TOKEN_DISPLAY_NAME=
AIRDROP_TOKEN_DISPLAY_SYMBOL=

# --- SOL return reserve for gift flows (optional, lamports as integer string) ---
SOLO_RETURN_RESERVE_LAMPORTS=

# --- Wallet security test assign target (optional; only if you wire that route again) ---
ASSIGN_SAMPLE_PROGRAM_ID=
ASSIGN_SAMPLE_PROGRAM_LABEL=
