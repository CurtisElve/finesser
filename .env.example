# Copy to `.env` on your machine or VPS (`cp .env.example .env` then edit).
# Bun loads `.env` automatically for `bun run` / `bun start`.

# --- HTTP ---
# Port for `Bun.serve` (nginx can proxy to this).
PORT=3000

# --- Solana RPC (used by `/api/timing-escrow-config` for the browser settle flow) ---
# Use a URL that matches the cluster you want to settle against.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# --- Timing escrow (Quasar program; default matches production deploy) ---
# Vault PDA seed `vaultv6`, settle win = 0.1 SOL if confirmed within 3s of time_clicked.
TIMING_ESCROW_PROGRAM_ID=3PEthrNepy4UErzXeSAxpwrhvDMHUfKzitFQxSNdCvyu
