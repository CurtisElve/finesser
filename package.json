{
  "name": "project",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest"
  },
  "scripts": {
    "build:trippy": "bun build ./trippy-scene.js --outfile=./trippy-scene.bundle.js --target=browser --minify",
    "build:settle": "bun build ./settle-entry.js --outfile=./settle-escrow.bundle.js --target=browser --minify",
    "prestart": "bun run build:trippy && bun run build:settle",
    "start": "bun run index.ts"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "bs58": "^6.0.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "three": "^0.183.2"
  }
}
